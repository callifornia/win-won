- git clone https://github.com/big-data-europe/docker-hadoop.git
- docker-compose up -d
	NameNode UI: 		http://localhost:9870
	ResourceManager UI: http://localhost:8088
	DataNode UI: 		http://localhost:9864

- docker cp /Users/hryhorii/Desktop/projects/hadoop-scala-docker/target/scala-2.13/hadoop-scala-docker-assembly-0.1.0-SNAPSHOT.jar namenode:/opt/
- docker cp /Users/hryhorii/Desktop/projects/hadoop-scala-docker/input.txt namenode:/opt/input.txt
- namenode# hdfs dfs -mkdir -p /input
- namenode# hdfs dfs -put /opt/input.txt /input/
- hadoop jar /opt/hadoop-scala-docker-assembly-0.1.0-SNAPSHOT.jar Main /input/input.txt /output
- hadoop fs -cat /output/part-r-00000 - print file into the console